{
  "name": "seen",
  "version": "0.1.0",
  "description": "Visibility engine for promotion-track engineers",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "capture": "node scripts/capture-flow.mjs",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "electron-builder install-app-deps",
    "build": "tsc && vite build && electron-builder",
    "build:renderer": "vite build",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "visibility",
    "promotion",
    "engineering",
    "career"
  ],
  "author": {
    "name": "Leela Kumili",
    "email": "leela.kumili@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.29.0",
    "better-sqlite3": "^12.5.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.372.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.22.3",
    "tailwind-merge": "^2.2.2",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.12.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^7.0.0",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.leelakumili.seen",
    "productName": "Seen",
    "copyright": "MIT © Leela Kumili",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "deb",
      "category": "Utility"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "db/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    }
  },
  "overrides": {
    "glob": "^13.0.0",
    "tar": "^7.5.13",
    "picomatch": "^4.0.4"
  },
  "engines": {
    "node": ">=20 <26"
  }
}
